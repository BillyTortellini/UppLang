

Node :: struct ($T)
    count: int
    value: T

foo :: fn(node: Node($K))
    node.count += 1

main :: fn()
    ~print_string("Hello world")
    ~print_line()
    
    x: * int
    
    node: Node(int) = .(15, 0)
    ~print_i32(node.value)
    ~print_line()
    
    bnode: Node(bool) = .(value = true, count = 0)
    ~print_bool(bnode.value)
