
Node :: struct ($T)
    count: int
    value: T

foo :: fn(node: *Node($K))
    node.count += 1

bar :: fn($C: int)
    x: int = C
    if true
        y: int = C

main :: fn()
    // bar(5)
    x: int = 5
    
    add_fn := fn(a: int, b: int) => int
        return a + b
    
    //  z := add_fn(1, 3)
    //   ~print_i32(z)
    //   ~print_line()
    
    node: Node(int) = .(15, 2)
    foo(node-*)
    ~print_i32(node.value)
    ~print_line()
    ~print_i32(node.count)
    ~print_line()
