

Node :: struct ($T)
    count: int
    value: T

foo :: fn(node: *Node($K))
    node.count += 1

bar :: fn($C: int)
    x: int = C
    z := C.asdf
    if true
        y: int = C

main :: fn()
    // bar(5)
    x: int = 5
    
    node: Node(int) = .(15, 2)
    foo(node-*)
    ~print_i32(node.value)
    ~print_line()
    ~print_i32(node.count)
    ~print_line()
